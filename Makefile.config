# Phlegethon Build Configuration (Default: pkg-config)
# ======================================================
# To switch machines, edit the include path below to point at the desired
# Make.<machine> file in Make.local/ (no copying required).
# Example: include ../../Make.local/Make.leidi

# This path has to be relative to wherever the actual Makefile is.
include ${SRC}/../Make.local/Make.pkgconfig

# Validate build options before compilation
include ${SRC}/../Make.checks

# Generic build rules shared by all test problems
all: $(EXE)

$(BUILD_DIR)/source.o: $(SRC)/source.F90
	$(FC) $(FFLAGS) -J $(BUILD_DIR) $(FC_OPTS) $(INCLUDE) -o $@ -c $<

$(BUILD_DIR)/$(APPNAME).o: $(APPNAME).F90
	$(FC) $(FFLAGS)  -J $(BUILD_DIR) $(FC_OPTS) $(INCLUDE) -o $@ -c $<

$(EXE): $(BUILD_DIR)/source.o $(BUILD_DIR)/$(APPNAME).o
	$(FC) $(FFLAGS) $(FC_OPTS) -o $@ $^  $(INCLUDE) $(LIBS) $(HDF5_LIB) $(RPATH)

clean:
	rm -f run.$(APPNAME)
	rm -rf $(BUILD_DIR)

$(shell mkdir -p $(BUILD_DIR))
$(shell touch restart_info.txt)
